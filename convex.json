{
  "$schema": "./node_modules/convex/schemas/convex.schema.json",
  "authKit": {
    "dev": {
      "configure": {
        "redirectUris": ["http://localhost:5173/callback"],
        "appHomepageUrl": "http://localhost:5173",
        "corsOrigins": ["http://localhost:5173"]
      },
      "localEnvVars": {
        "VITE_WORKOS_CLIENT_ID": "${authEnv.WORKOS_CLIENT_ID}",
        "VITE_WORKOS_REDIRECT_URI": "http://localhost:5173/callback"
      }
    },
    "preview": {
      "configure": {
        "redirectUris": ["${buildEnv.DEPLOY_PRIME_URL}/callback"],
        "appHomepageUrl": "${buildEnv.DEPLOY_PRIME_URL}",
        "corsOrigins": ["${buildEnv.DEPLOY_PRIME_URL}"]
      }
    },
    "prod": {
      "configure": {
        "redirectUris": ["${buildEnv.URL}/callback"],
        "appHomepageUrl": "${buildEnv.URL}",
        "corsOrigins": ["${buildEnv.URL}"]
      }
    }
  }
}
